@model SV22T1020193.Models.Partner.Customer

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="text-primary fw-bold">
                <i class="fa fa-user-circle me-2"></i> Hồ sơ của bạn
            </h3>
            <p class="text-muted">Quản lý thông tin cá nhân và bảo mật tài khoản</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="fa fa-id-card text-secondary me-2"></i> Thông tin cơ bản</h5>
                </div>
                <div class="card-body">

                    @if (TempData["ProfileMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fa fa-check-circle me-1"></i> @TempData["ProfileMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["ProfileError"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fa fa-exclamation-triangle me-1"></i> @TempData["ProfileError"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Profile" asp-controller="Account" method="post">
                        <input type="hidden" asp-for="CustomerID" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="IsLocked" />

                        <div class="mb-3">
                            <label class="form-label text-muted fw-medium">Email đăng nhập</label>
                            <input type="text" class="form-control bg-light" value="@Model.Email" readonly disabled />
                            <small class="text-muted">Email được dùng làm tài khoản đăng nhập nên không thể thay đổi.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium">Họ và tên khách hàng <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" asp-for="CustomerName" required />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Tên giao dịch (Biệt danh)</label>
                                <input type="text" class="form-control" asp-for="ContactName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium">Số điện thoại</label>
                                <input type="text" class="form-control" asp-for="Phone" />
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-5">
                                <label class="form-label fw-medium">Tỉnh / Thành phố</label>
                                <select class="form-select" asp-for="Province">
                                    <option value="">-- Chọn Tỉnh/Thành --</option>
                                    @if (ViewBag.Provinces != null)
                                    {
                                        foreach (var p in ViewBag.Provinces)
                                        {
                                            if (p.ProvinceName == Model.Province)
                                            {
                                                <option value="@p.ProvinceName" selected>@p.ProvinceName</option>
                                            }
                                            else
                                            {
                                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                                            }
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-7">
                                <label class="form-label fw-medium">Địa chỉ chi tiết</label>
                                <input type="text" class="form-control" asp-for="Address" placeholder="Số nhà, tên đường, phường/xã..." />
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="button" onclick="history.back()" class="btn btn-secondary px-4 py-2 rounded-pill fw-medium me-2">
                                <i class="fa fa-arrow-left me-1"></i> Quay lại
                            </button>
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-medium">
                                <i class="fa fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5 mb-4">
            <div class="card shadow-sm border-0 h-100 bg-light">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="fa fa-shield-alt text-warning me-2"></i> Đổi mật khẩu</h5>
                </div>
                <div class="card-body">

                    <div id="ajaxMessage" class="alert d-none" role="alert"></div>

                    <form id="frmChangePassword">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="oldPassword" name="oldPassword" placeholder="Nhập mật khẩu cũ..." required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Mật khẩu từ 6 ký tự..." required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu mới..." required />
                        </div>

                        <div class="d-grid">
                            <button type="button" id="btnChangePassword" class="btn btn-warning text-dark py-2 rounded-pill fw-bold">
                                <i class="fa fa-key me-1"></i> Cập nhật mật khẩu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Khi click vào nút Đổi mật khẩu
            $("#btnChangePassword").click(function () {
                var oldPw = $("#oldPassword").val().trim();
                var newPw = $("#newPassword").val().trim();
                var confirmPw = $("#confirmPassword").val().trim();
                var msgBox = $("#ajaxMessage");

                // Reset thông báo
                msgBox.removeClass("alert-success alert-danger d-none").text("");

                // 1. Kiểm tra đầu vào (Client-side validation)
                if (oldPw === "" || newPw === "" || confirmPw === "") {
                    msgBox.addClass("alert-danger").text("Vui lòng điền đầy đủ thông tin vào các ô mật khẩu.").removeClass("d-none");
                    return;
                }

                if (newPw !== confirmPw) {
                    msgBox.addClass("alert-danger").text("Mật khẩu xác nhận không khớp.").removeClass("d-none");
                    return;
                }

                if (newPw.length < 6) {
                    msgBox.addClass("alert-danger").text("Mật khẩu mới phải có ít nhất 6 ký tự.").removeClass("d-none");
                    return;
                }

                // 2. Vô hiệu hóa nút bấm và tạo hiệu ứng loading
                var btn = $(this);
                var originalText = btn.html();
                btn.prop("disabled", true).html('<i class="fa fa-spinner fa-spin me-1"></i> Đang xử lý...');

                // 3. Gửi request bằng AJAX lên server
                $.ajax({
                    url: '@Url.Action("ChangePassword", "Account")', // Đường dẫn gọi đến hàm trong AccountController
                    type: 'POST',
                    data: {
                        oldPassword: oldPw,
                        newPassword: newPw,
                        confirmPassword: confirmPw
                    },
                    success: function (response) {
                        if (response.success) {
                            // Nếu Controller trả về success = true
                            msgBox.addClass("alert-success").html('<i class="fa fa-check-circle me-1"></i> ' + response.message).removeClass("d-none");
                            $("#frmChangePassword")[0].reset(); // Xóa trắng form đổi mật khẩu
                        } else {
                            // Nếu Controller trả về success = false (sai mật khẩu cũ...)
                            msgBox.addClass("alert-danger").html('<i class="fa fa-exclamation-triangle me-1"></i> ' + response.message).removeClass("d-none");
                        }
                    },
                    error: function () {
                        // Bắt lỗi khi mất mạng hoặc lỗi server 500
                        msgBox.addClass("alert-danger").html('<i class="fa fa-times-circle me-1"></i> Lỗi kết nối đến máy chủ. Vui lòng thử lại!').removeClass("d-none");
                    },
                    complete: function () {
                        // 4. Mở khóa lại nút bấm khi xử lý xong (dù thành công hay thất bại)
                        btn.prop("disabled", false).html(originalText);
                    }
                });
            });
        });
    </script>
}