@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-primary">Đăng nhập</h3>
                        <p class="text-muted">Chào mừng bạn quay lại MyShop</p>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success rounded-3">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger rounded-3">
                            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control bg-light border-0 py-2" name="userName" required placeholder="name@example.com" autofocus />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium d-flex justify-content-between">
                                <span>Mật khẩu <span class="text-danger">*</span></span>
                            </label>
                            <input type="password" class="form-control bg-light border-0 py-2" name="password" required placeholder="Nhập mật khẩu" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2 rounded-3 fw-bold">Đăng nhập</button>
                        </div>

                        <div class="text-center mt-4 text-muted">
                            Chưa có tài khoản? <a asp-controller="Account" asp-action="Register" class="text-primary text-decoration-none fw-bold">Đăng ký ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>