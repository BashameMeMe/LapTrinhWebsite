@model SV22T1020193.Models.Catalog.Product
@{
    // Bỏ Layout = null; đi để View nhận giao diện chung (Navbar, Footer)
    ViewData["Title"] = Model.ProductName;
}

<div class="container mt-4 mb-5 pb-5">

    <div class="mb-4">
        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill shadow-sm text-decoration-none">
            <i class="fa fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center g-5">

                <div class="col-md-5 text-center position-relative">
                    <img src="@(string.IsNullOrEmpty(Model.Photo) ? Url.Content("~/images/products/demo.png") : Url.Content($"~/images/products/{Model.Photo}"))"
                         class="img-fluid rounded-4 shadow" style="object-fit: cover; max-height: 500px; width: 100%;" alt="@Model.ProductName" />

                    @if (!Model.IsSelling)
                    {
                        <div class="position-absolute top-0 start-0 m-4">
                            <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm">Ngừng bán</span>
                        </div>
                    }
                </div>

                <div class="col-md-7">
                    <span class="text-uppercase text-primary fw-bold mb-2 d-block" style="font-size: 0.85rem; letter-spacing: 1px;">
                        <i class="fa fa-tag me-1"></i> Thông tin sản phẩm
                    </span>

                    <h2 class="fw-bold text-dark mb-3">@Model.ProductName</h2>
                    <h1 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0") đ</h1>

                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <div class="bg-light px-4 py-2 rounded-pill border">
                            <i class="fa fa-box text-secondary me-1"></i>
                            <span class="text-muted">Đơn vị:</span>
                            <strong class="text-dark">@Model.Unit</strong>
                        </div>

                        <div class="bg-light px-4 py-2 rounded-pill border">
                            <i class="fa fa-info-circle text-secondary me-1"></i>
                            <span class="text-muted">Trạng thái:</span>
                            @if (Model.IsSelling)
                            {
                                <span class="text-success fw-bold"><i class="fa fa-check-circle me-1"></i> Đang bán</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold"><i class="fa fa-times-circle me-1"></i> Ngừng bán</span>
                            }
                        </div>
                    </div>

                    <div class="mb-5 bg-light p-4 rounded-4 border">
                        <h6 class="fw-bold mb-3">Mô tả chi tiết:</h6>
                        <p class="text-muted mb-0" style="line-height: 1.8;">
                            @(string.IsNullOrWhiteSpace(Model.ProductDescription) ? "Chưa có mô tả cho sản phẩm này." : Model.ProductDescription)
                        </p>
                    </div>

                    <div class="d-grid gap-3 d-md-flex">
                        @if (Model.IsSelling)
                        {
                            <button class="btn btn-primary btn-lg rounded-pill fw-medium shadow-sm px-5" onclick="addToCart(@Model.ProductID, '@Model.ProductName', @Model.Price)">
                                <i class="fa fa-cart-plus me-2"></i> Thêm vào giỏ hàng
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg rounded-pill fw-medium px-5" disabled>
                                <i class="fa fa-ban me-2"></i> Sản phẩm đã ngừng bán
                            </button>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function addToCart(productId, productName, price) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: {
                    ProductID: productId,
                    ProductName: productName,
                    SalePrice: price,
                    Quantity: 1
                },
                success: function (response) {
                    showToast('Đã thêm [' + productName + '] vào giỏ hàng!');
                },
                error: function () {
                    showToast('Lỗi khi thêm sản phẩm!', true);
                }
            });
        }

        function showToast(message, isError = false) {
            let toast = $('<div></div>')
                .text(message)
                .css({
                    position: 'fixed',
                    top: '20px',
                    right: '20px',
                    background: isError ? '#e74c3c' : '#2ecc71',
                    color: '#fff',
                    padding: '10px 20px',
                    borderRadius: '5px',
                    zIndex: 9999
                });

            $('body').append(toast);

            setTimeout(function () {
                toast.fadeOut(500, function () {
                    $(this).remove();
                });
            }, 500);
        }
    </script>
}