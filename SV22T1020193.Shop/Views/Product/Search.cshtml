@model SV22T1020193.Models.Common.PagedResult<SV22T1020193.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-secondary fw-normal">Tìm thấy <strong>@Model.RowCount</strong> sản phẩm</h5>
</div>

@if (Model.DataItems.Any())
{
    <div class="row g-4">
        @foreach (var item in Model.DataItems)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0 product-card hover-shadow">

                    <div class="position-relative overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(item.Photo) ? Url.Content("~/images/products/demo.png") : Url.Content($"~/images/products/{item.Photo}"))"
                             class="card-img-top" style="height:250px; object-fit:cover;" alt="@item.ProductName" />

                        @if (!item.IsSelling)
                        {
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-danger">Ngừng bán</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h6 class="card-title mb-1 text-truncate" title="@item.ProductName">
                            <a href="@Url.Action("Details", "Product", new { id = item.ProductID })" class="text-dark text-decoration-none stretched-link">
                                @item.ProductName
                            </a>
                        </h6>

                        <p class="small text-muted mb-2 text-truncate-2 flex-grow-1">@item.ProductDescription</p>

                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="text-danger fw-bold fs-5">@item.Price.ToString("N0") đ</span>

                            <button class="btn btn-outline-primary btn-sm rounded-circle position-relative" style="z-index: 10;" onclick="addToCart(@item.ProductID, '@item.ProductName', @item.Price)">
                                <i class="fa fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <nav class="mt-5">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                <li class="page-item @(p.IsCurrent ? "active" : "") @(p.IsEllipsis ? "disabled" : "")">
                    <a class="page-link border-0 shadow-sm mx-1 rounded-3" href="javascript:;"
                       onclick="return paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                        @(p.IsEllipsis ? "..." : p.Page.ToString())
                    </a>
                </li>
            }
        </ul>
    </nav>
}
else
{
    <div class="text-center py-5">
        <i class="fa-solid fa-box-open fs-1 text-muted mb-3"></i>
        <p class="text-muted">Không tìm thấy sản phẩm nào phù hợp.</p>
    </div>
}

<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>
