@model PagedResult<Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="@Url.Action("Search", "Product")"
              data-target="searchResult"
              onsubmit="return paginationSearch(event, this, 1);">
            <div class="row g-2">


                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <!-- 🔹 Category -->
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" name="CategoryID" asp-items="await SelectListHelper.Categories()"></select>

                </div>

                <!-- 🔹 Supplier -->
                <div class="col-md-3">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="SupplierID" asp-items="await SelectListHelper.Suppliers()"></select>
                </div>

                <!-- 🔹 Price -->
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                               name="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               name="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <!-- 🔹 Search -->
                <div class="col-md-3">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               name="SearchValue"
                               value="@ViewBag.SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    @await Html.PartialAsync("Search", Model)
</div>

<!-- Modal for Product Details -->
<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div id="productModalContent">
                <!-- Content will be loaded here via AJAX -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. HÀM XỬ LÝ TÌM KIẾM VÀ PHÂN TRANG BẰNG AJAX (KHÔNG RELOAD)
        function paginationSearch(e, form, page) {
            // Chặn sự kiện submit form hoặc click thẻ <a> mặc định (tránh reload trang)
            if (e) {
                e.preventDefault();
            }

            // Lấy thông tin từ form
            let url = $(form).attr('action'); // /Product/Search
            let method = $(form).attr('method') || 'GET';
            let target = $(form).data('target'); // searchResult

            // Lấy toàn bộ dữ liệu đang nhập trên form
            let formData = $(form).serializeArray();
            // Đẩy thêm số trang cần chuyển tới vào dữ liệu gửi lên Controller
            formData.push({ name: 'page', value: page });

            // Gọi AJAX
            $.ajax({
                url: url,
                type: method,
                data: $.param(formData), // Chuyển thành chuỗi query để gửi đi
                success: function (response) {
                    // Cập nhật lại HTML của vùng hiển thị danh sách sản phẩm
                    $('#' + target).html(response);
                },
                error: function () {
                    showToast('Lỗi không thể tải dữ liệu trang!', true);
                }
            });

            return false;
        }

        // ==========================================
        // CÁC HÀM CŨ CỦA BẠN GIỮ NGUYÊN BÊN DƯỚI
        // ==========================================

        function showProductDetails(productId) {
            fetch(`/Product/Details/${productId}`)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('productModalContent').innerHTML = html;
                    var modal = new bootstrap.Modal(document.getElementById('productModal'));
                    modal.show();
                })
                .catch(error => {
                    console.error('Error loading product details:', error);
                    alert('Không thể tải chi tiết sản phẩm.');
                });
        }

        function addToCart(productId, productName, price) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: {
                    ProductID: productId,
                    ProductName: productName,
                    SalePrice: price,
                    Quantity: 1
                },
                success: function (response) {
                    showToast('Đã thêm [' + productName + '] vào giỏ hàng!');
                },
                error: function () {
                    showToast('Lỗi khi thêm sản phẩm!', true);
                }
            });
        }

        function showToast(message, isError = false) {
            let toast = $('<div></div>')
                .text(message)
                .css({
                    position: 'fixed',
                    top: '20px',
                    right: '20px',
                    background: isError ? '#e74c3c' : '#2ecc71',
                    color: '#fff',
                    padding: '10px 20px',
                    borderRadius: '5px',
                    zIndex: 9999
                });

            $('body').append(toast);

            setTimeout(function () {
                toast.fadeOut(500, function () {
                    $(this).remove();
                });
            }, 1000); // Đổi thành 1000ms (1 giây) cho dễ nhìn hơn
        }
    </script>
}