@model List<SV22T1020193.Models.Sales.OrderDetailViewInfo>
@{
    ViewData["Title"] = "Xác nhận đơn hàng";
}

<div class="container mt-4 mb-5">
    <h2 class="theme-blue fw-bold mb-4">Xác nhận thông tin đặt hàng</h2>

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm border-theme-blue">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Danh sách sản phẩm</h5>
                    <table class="table align-middle">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductName x @item.Quantity</td>
                                <td class="text-end fw-bold">@((item.Quantity * item.SalePrice).ToString("N0")) ₫</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow border-theme-blue">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Thông tin giao hàng</h5>
                    <form action="~/Cart/InitOrder" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tỉnh/Thành phố</label>
                            <select name="deliveryProvince" class="form-select rounded-pill" required>
                                <option value="">-- Chọn Tỉnh/Thành phố --</option>
                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var p in (List<Province>)ViewBag.Provinces)
                                    {
                                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                            <textarea name="deliveryAddress" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã..." required></textarea>
                        </div>

                        <div class="bg-light p-3 rounded-3 mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">Tổng cộng:</span>
                                <span class="text-danger fw-bold fs-4">@Model.Sum(x => x.Quantity * x.SalePrice).ToString("N0") ₫</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-blue btn-lg w-100 rounded-pill shadow">
                            <i class="bi bi-check2-circle me-2"></i> HOÀN TẤT ĐẶT HÀNG
                        </button>
                        <a href="~/Cart" class="btn btn-link w-100 text-decoration-none mt-2 text-muted">Quay lại giỏ hàng</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>