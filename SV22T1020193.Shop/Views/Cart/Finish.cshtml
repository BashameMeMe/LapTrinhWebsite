@{
    ViewData["Title"] = "Đặt hàng thành công";
    int orderId = ViewBag.OrderID ?? 0;
}

<div class="container mt-5 mb-5 text-center">
    <div class="card shadow border-0 py-5 px-4" style="border-radius: 20px;">
        <div class="card-body">
            <div class="mb-4">
                <div class="display-1 text-success">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>

            <h1 class="fw-bold text-dark mb-3">Đặt hàng thành công!</h1>

            <p class="fs-5 text-muted mb-4">
                Cảm ơn bạn đã tin tưởng mua sắm. <br />
                Mã đơn hàng của bạn là: <strong class="text-primary">#@orderId</strong>
            </p>

            <div class="alert alert-info d-inline-block px-4 py-3 rounded-pill mb-4">
                <i class="bi bi-info-circle me-2"></i>
                Chúng tôi sẽ sớm liên hệ với bạn để xác nhận đơn hàng.
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="~/Home" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                    <i class="bi bi-house-door me-2"></i> Về trang chủ
                </a>
                <a href="~/Product" class="btn btn-primary btn-lg rounded-pill px-4 shadow">
                    <i class="bi bi-bag-plus me-2"></i> Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .bi-check-circle-fill {
        animation: scaleIn 0.5s ease-out;
    }

    @@keyframes scaleIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        80% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>