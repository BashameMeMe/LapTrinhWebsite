<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-2">
        <div class="container">

            <a class="navbar-brand fw-bold text-primary fs-4" asp-controller="Home" asp-action="Index">
                🛍 MyShop
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link fw-medium" asp-controller="Product" asp-action="Index">
                            Mua hàng
                        </a>
                    </li>
                </ul>
                <div class="navbar-nav align-items-center">

                    <a class="nav-link btn btn-light me-3 px-3 rounded-pill border" asp-controller="Cart" asp-action="Index">
                        <i class="fa fa-shopping-cart text-primary"></i> Giỏ hàng
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle btn btn-outline-primary rounded-pill px-3 py-1" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa fa-user-circle me-1"></i> Xin chào, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li>
                                    <a class="dropdown-item py-2" href="#">
                                        <i class="fa fa-list me-2"></i> Lịch sử mua hàng
                                    </a>
                                    <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                        <i class="fa fa-user me-2"></i> Thông tin cá nhân
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger py-2" asp-controller="Account" asp-action="Logout">
                                        <i class="fa fa-sign-out-alt me-2"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-link btn btn-primary text-white px-4 py-1 rounded-pill fw-medium me-2" asp-controller="Account" asp-action="Login">
                            Đăng nhập
                        </a>
                        <a class="nav-link btn btn-outline-primary px-4 py-1 rounded-pill fw-medium" asp-controller="Account" asp-action="Register">
                            Đăng ký
                        </a>
                    }
                </div>

            </div>
        </div>
    </nav>
</header>