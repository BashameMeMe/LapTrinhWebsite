@model Category
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-tags me-2"></i>
                    Thông tin loại hàng
                </h5>
            </div>

            <div class="card-body">
                @* Thêm action để biết form sẽ gửi dữ liệu đi đâu *@
                <form id="formEdit" action="~/Category/SaveData" method="post">

                    @* BẮT BUỘC: Thẻ ẩn để giữ ID của loại hàng (nếu không có cái này, mọi thao tác cập nhật sẽ bị biến thành thêm mới) *@
                    <input type="hidden" name="@nameof(Model.CategoryID)" value="@Model.CategoryID" />

                    <div class="mb-3">
                        <label class="form-label">Tên loại hàng</label>
                        @* Thêm name và value để hiển thị và gửi dữ liệu *@
                        <input type="text"
                               class="form-control"
                               name="@nameof(Model.CategoryName)"
                               value="@Model.CategoryName"
                               placeholder="Nhập tên loại hàng" autofocus />
                        @* Hiển thị lỗi nếu người dùng để trống *@
                        @Html.ValidationMessage(nameof(Model.CategoryName), "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        @* Thêm name và giá trị hiển thị bên trong thẻ textarea *@
                        <textarea class="form-control"
                                  name="@nameof(Model.Description)"
                                  rows="4"
                                  placeholder="Nhập mô tả loại hàng">@Model.Description</textarea>
                    </div>

                    @* Hiển thị thông báo lỗi chung của hệ thống (nếu có) *@
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                </form>
            </div>
        </div>
    </div>
</div>