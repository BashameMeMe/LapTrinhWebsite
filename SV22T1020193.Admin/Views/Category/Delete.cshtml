@model Category
@{
    ViewBag.Title = "Xóa loại hàng";
}

@section PageToolBar {
    @* BỔ SUNG: Chỉ hiện nút Xóa nếu loại hàng này được phép xóa *@
    @if (ViewBag.AllowDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa loại hàng
                </h5>
            </div>

            <div class="card-body">
                @* BỔ SUNG: Thêm action để biết form gửi lệnh xóa cho ai *@
                <form id="formDelete" action="~/Category/Delete/@Model.CategoryID" method="post">

                    @* BỔ SUNG: Hiển thị cảnh báo dựa trên việc có được xóa hay không *@
                    @if (ViewBag.AllowDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa loại hàng này không?
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-x-octagon-fill me-2"></i>
                            <strong>Không thể xóa:</strong> Loại hàng này đang có mặt hàng sử dụng. Bạn chỉ có thể quay lại hoặc cập nhật thông tin.
                        </div>
                    }

                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tên loại hàng</dt>
                        @* BỔ SUNG: Lấy tên loại hàng từ Model *@
                        <dd class="col-sm-9 fw-bold">@Model.CategoryName</dd>

                        <dt class="col-sm-3">Mô tả</dt>
                        @* BỔ SUNG: Lấy mô tả từ Model *@
                        <dd class="col-sm-9">
                            @(string.IsNullOrWhiteSpace(Model.Description) ? "--- Chưa có mô tả ---" : Model.Description)
                        </dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>