@{
    ViewBag.Title = "Thay đổi mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-11 col-sm-8 col-md-6 col-lg-4">
        <form action="~/Account/ChangePassword" method="post">
            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 50px; height: 50px;">
                            <i class="bi bi-shield-lock fs-3"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-1">@ViewBag.Title</h5>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger rounded-3 shadow-sm py-2 px-3 small">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                            @Html.ValidationSummary(true, "")
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark small mb-1">Mật khẩu cũ <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0 px-3">
                                <i class="bi bi-unlock"></i>
                            </span>
                            <input type="password" class="form-control border-start-0 ps-0" name="oldPassword" placeholder="Nhập mật khẩu cũ..." required autofocus>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark small mb-1">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-primary border-end-0 px-3">
                                <i class="bi bi-key"></i>
                            </span>
                            <input type="password" class="form-control border-start-0 ps-0" name="newPassword" placeholder="Nhập mật khẩu mới..." required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark small mb-1">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-primary border-end-0 px-3">
                                <i class="bi bi-check2-circle"></i>
                            </span>
                            <input type="password" class="form-control border-start-0 ps-0" name="confirmPassword" placeholder="Nhập lại mật khẩu..." required>
                        </div>
                    </div>

                    <div class="row g-2 mt-2">
                        <div class="col-6">
                            <a href="~/" class="btn btn-light border w-100 py-2 fw-semibold text-secondary rounded-3 small">
                                <i class="bi bi-arrow-left me-1"></i> Bỏ qua
                            </a>
                        </div>
                        <div class="col-6">
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm rounded-3 small">
                                <i class="bi bi-check2 me-1"></i> Cập nhật
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>