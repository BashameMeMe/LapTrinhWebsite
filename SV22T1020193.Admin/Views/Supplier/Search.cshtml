@model SV22T1020193.Models.Common.PagedResult<SV22T1020193.Models.Partner.Supplier>

<div class="mb-2 text-muted">
    Có <strong>@Model.RowCount</strong> nhà cung cấp
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Tên NCC</th>
            <th>Giao dịch</th>
            <th>Điện thoại</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.DataItems.Any())
        {
            foreach (var item in Model.DataItems)
            {
                <tr>
                    <td>@item.SupplierName</td>
                    <td>@item.ContactName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>
                        <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-sm btn-primary">Sửa</a>
                        <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Không có dữ liệu</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.PageCount > 1)
{
    <ul class="pagination">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(@(Model.Page - 1))">«</a>
        </li>

        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.IsEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }
            else
            {
                <li class="page-item @(p.IsCurrent ? "active" : "")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(@p.Page)">@p.Page</a>
                </li>
            }
        }

        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(@(Model.Page + 1))">»</a>
        </li>
    </ul>
}