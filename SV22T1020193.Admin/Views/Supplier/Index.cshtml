@model SV22T1020193.Models.Common.PaginationSearchInput

@{
    ViewBag.Title = "Quản lý nhà cung cấp";
}

<h2>Quản lý nhà cung cấp</h2>

<form id="formSearch" method="post" action="~/Supplier/Search">
    <div class="row mb-2">
        <div class="col-md-4">
            <input type="text" name="SearchValue"
                   class="form-control"
                   placeholder="Tìm nhà cung cấp..."
                   value="@Model.SearchValue" />
        </div>

        <div class="col-md-2">  
            <button type="submit" class="btn btn-primary">
                Tìm kiếm
            </button>
        </div>

        <!-- ✅ Nút thêm -->
        <div class="col-md-3 text-end">
            <a href="~/Supplier/Create" class="btn btn-primary">
                + Bổ sung nhà cung cấp
            </a>
        </div>
    </div>

    <input type="hidden" name="Page" value="@Model.Page" />
    <input type="hidden" name="PageSize" value="@Model.PageSize" />
</form>

<div id="searchResult"></div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {

        loadData();

        $("#formSearch").submit(function (e) {
            e.preventDefault();
            loadData();
        });
    });

    function loadData() {
        $.ajax({
            url: '/Supplier/Search',
            type: 'POST',
            data: $("#formSearch").serialize(),
            success: function (data) {
                $("#searchResult").html(data);
            }
        });
    }

    function paginationSearch(page) {
        $("input[name='Page']").val(page);
        loadData();
    }
</script>