@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">Xóa mặt hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form method="post" asp-action="DeleteCartItem" asp-controller="Order">
    <input type="hidden" name="id" value="@ViewBag.OrderId" />
    <input type="hidden" name="productId" value="@ViewBag.ProductId" />

    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có muốn xóa mặt hàng này ra khỏi đơn hàng không?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>