@{
    Layout = null;
}

<form id="formClearCart" method="post" action="~/Order/ClearCart">
    <div class="modal-header text-bg-danger">
        <strong class="modal-title">
            Xóa giỏ hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có chắc chắn muốn xóa tất cả các mặt hàng trong giỏ hàng không?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).on("submit", "#formClearCart", function (e) {
        e.preventDefault();

        var form = $(this);

        $.post(form.attr("action"), function (res) {

            if (res.code == 1) {   // 🔥 đúng theo ApiResult
                loadCart();        // load lại giỏ hàng

                // đóng modal
                var modalEl = document.querySelector('.modal.show');
                if (modalEl) {
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                }
            } else {
                alert(res.message);
            }

        });
    });
</script>