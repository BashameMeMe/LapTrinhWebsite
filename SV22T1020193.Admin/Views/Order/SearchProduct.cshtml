@model PagedResult<Product>
@{
    Layout = null;
}

@foreach (var item in Model.DataItems)
{
    <form method="post" action="~/Order/AddCartItem" class="border rounded p-2 mb-2 cart-item-form">
        <input type="hidden" name="productId" value="@item.ProductID" />

        <strong>@item.ProductName</strong>

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@item.Photo" class="img-fluid border" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <input class="form-control form-control-sm"
                               name="price"
                               value="@item.Price" />
                    </div>
                    <div class="col-5">
                        <input type="number" name="quantity" value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button class="btn btn-sm btn-primary mt-2 w-100">
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}
<nav class="mt-2">
    <ul class="pagination pagination-sm justify-content-center mb-0">

        <!-- Previous -->
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;" onclick="searchProduct(@(Model.Page - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        <!-- Page numbers -->
        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.IsEllipsis)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
            else
            {
                <li class="page-item @(p.IsCurrent ? "active" : "")">
                    <a class="page-link" href="javascript:;" onclick="searchProduct(@p.Page)">
                        @p.Page
                    </a>
                </li>
            }
        }

        <!-- Next -->
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;" onclick="searchProduct(@(Model.Page + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>

    </ul>
</nav>