@model List<SV22T1020193.Models.Sales.OrderDetailViewInfo>
@{
    Layout = null;
    int stt = 0;
}

<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@(++stt)</td>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end">@item.TotalPrice.ToString("N0")</td>

                            <td class="text-end">
                                <!-- EDIT -->
                                <a href="~/Order/EditCartItem?productId=@item.ProductID"
                                   class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <!-- DELETE -->
                                <a href="~/Order/DeleteCartItem?id=0&productId=@item.ProductID"
                                   class="btn btn-sm btn-danger ajax-cart-action">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">
                            Không có sản phẩm nào
                        </td>
                    </tr>
                }
            </tbody>

            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">
                        @(Model?.Sum(x => x.Quantity * x.SalePrice).ToString("N0"))
                    </th>
                    <th></th>
                </tr>
            </tfoot>
        </table>

        <div class="text-end">
            <a href="~/Order/ClearCart"
               class="btn btn-sm btn-danger mt-2 ajax-cart-action"
               data-method="post">
                <i class="bi bi-trash"></i>
                Xóa giỏ hàng
            </a>
        </div>
    </div>
</div>