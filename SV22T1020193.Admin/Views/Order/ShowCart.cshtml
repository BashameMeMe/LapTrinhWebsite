@model List<OrderDetailViewInfo>
@{
    Layout = null;
    decimal total = 0;
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Tên</th>
            <th>SL</th>
            <th>Giá</th>
            <th>Tiền</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            int i = 1;
            foreach (var item in Model)
            {
                total += item.TotalPrice;
                <tr>
                    <td>@i++</td>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.SalePrice</td>
                    <td>@item.TotalPrice</td>
                    <td>
                        <a href="~/Order/DeleteCartItem?productId=@item.ProductID"
                           class="btn btn-danger ajax-cart-action">X</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="6">Giỏ trống</td></tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="4">Tổng</th>
            <th>@total</th>
            <th></th>
        </tr>
    </tfoot>
</table>

<a href="~/Order/ClearCart" class="btn btn-danger ajax-cart-action">
    Xóa giỏ
</a>