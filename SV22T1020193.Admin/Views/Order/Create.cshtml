@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- LEFT -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form id="formSearchProduct" method="get" action="~/Order/SearchProduct" class="mb-3">
                    <div class="input-group">
                        <input class="form-control" name="searchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- AJAX -->
                <div id="searchProductResult"></div>
            </div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="col-8">
        <div id="showCart"></div>

        <!-- FORM ORDER giữ nguyên -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form id="formOrder" method="post" action="~/Order/CreateOrder">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerId">
                                        <option value="">-- Chọn khách hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province">
                                        <option value="">-- Chọn tỉnh --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary">
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
        $(document).ready(function () {

            // ================= INIT =================
            searchProduct(1);
            loadCart();

            // ================= SEARCH PRODUCT =================
            $("#formSearchProduct").submit(function (e) {
                e.preventDefault();
                searchProduct(1);
            });

            // ================= ADD / UPDATE ITEM =================
            $(document).on("submit", ".cart-item-form", function (e) {
                e.preventDefault();
                var f = $(this);

                $.post(f.attr("action"), f.serialize(), function () {
                    loadCart();
                });
            });

            // ================= OPEN EDIT =================
            $(document).on("click", ".open-modal", function (e) {
                e.preventDefault();

                $.get($(this).attr("href"), function (html) {
                    $("#showCart").html(html);
                });
            });

            // ================= UPDATE CART =================
            $(document).on("click", "#btnUpdateCart", function () {
                var f = $("#formEditCart");

                if (f.length === 0) {
                    console.log("Không tìm thấy formEditCart");
                    return;
                }

                $.post(f.attr("action"), f.serialize(), function (res) {
                    console.log(res);

                    if (res.code == 1) {
                        loadCart();
                    } else {
                        alert(res.message);
                    }
                });
            });

            // ================= DELETE / CLEAR =================
                $(document).on("click", ".ajax-cart-action", function (e) {
        e.preventDefault();

        var url = $(this).attr("href");

        $.post(url, function () {
            loadCart();
        });
    });

            // ================= CLOSE EDIT =================
            $(document).on("click", ".btn-close-cart", function () {
                loadCart();
            });

            // ================= CREATE ORDER =================
            $("#formOrder").submit(function (e) {
                e.preventDefault();
                var f = $(this);

                $.post(f.attr("action"), f.serialize(), function (res) {
                    if (res.success) {
                        alert("Tạo đơn thành công!");
                        loadCart();
                    } else {
                        alert(res.message);
                    }
                });
            });
        });

        // ================= FUNCTIONS =================

        function searchProduct(page) {
            $.get('@Url.Action("SearchProduct", "Order")', {
                searchValue: $("input[name='searchValue']").val(),
                page: page,
                pageSize: 5
            }, function (html) {
                $("#searchProductResult").html(html);
            });
        }

        function loadCart() {
            $.get('@Url.Action("ShowCart", "Order")', function (html) {
                $("#showCart").html(html);
            });
        }
</script>
