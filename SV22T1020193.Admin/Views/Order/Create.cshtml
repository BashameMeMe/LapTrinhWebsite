@model Customer
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- LEFT -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form id="formSearchProduct" method="get" action="~/Order/SearchProduct" class="mb-3">
                    <div class="input-group">
                        <input class="form-control" name="searchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- AJAX -->
                <div id="searchProductResult"></div>
            </div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="col-8">
        <div id="showCart"></div>

        <!-- FORM ORDER giữ nguyên -->
        <div class="col-12">
            <div id="showCart"></div>

            <!-- FORM ORDER -->
            <div class="card card-outline card-info mt-5">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-person"></i>
                        Thông tin khách hàng & nơi giao hàng
                    </h5>
                </div>

                <div class="card-body">
                    <form id="formOrder" method="post" asp-action="CreateOrder" asp-controller="Order">

                        <!-- CUSTOMER -->
                        <div class="row mb-3 align-items-center">
                            <label class="col-md-3 col-form-label text-md-end">
                                Khách hàng
                            </label>
                            <div class="col-md-9">
                                <select class="form-select" asp-for="CustomerID">
                                    <option value="">-- Chọn khách hàng --</option>
                                </select>
                                <span asp-validation-for="CustomerID" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- PROVINCE -->
                        <div class="row mb-3 align-items-center">
                            <label class="col-md-3 col-form-label text-md-end">
                                Tỉnh / Thành
                            </label>
                            <div class="col-md-9">
                                <select class="form-select" asp-for="Province">
                                    <option value="">-- Chọn tỉnh --</option>
                                </select>
                                <span asp-validation-for="Province" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- ADDRESS -->
                        <div class="row mb-3">
                            <label class="col-md-3 col-form-label text-md-end">
                                Địa chỉ
                            </label>
                            <div class="col-md-9">
                                <textarea class="form-control"
                                          asp-for="Address"
                                          rows="3"
                                          placeholder="Nhập địa chỉ giao hàng"></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- BUTTON -->
                        <div class="text-end">
                            <button class="btn btn-primary px-4">
                                <i class="bi bi-check"></i>
                                Lập đơn hàng
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
        $(document).ready(function () {

            // ================= INIT =================
            searchProduct(1);
            loadCart();

            // ================= SEARCH PRODUCT =================
            $("#formSearchProduct").submit(function (e) {
                e.preventDefault();
                searchProduct(1);
            });

            // ================= ADD / UPDATE ITEM =================
            $(document).on("submit", ".cart-item-form", function (e) {
                e.preventDefault();
                var f = $(this);

                $.post(f.attr("action"), f.serialize(), function () {
                    loadCart();
                });
            });

            // ================= OPEN EDIT =================
            $(document).on("click", ".open-modal", function (e) {
                e.preventDefault();

                $.get($(this).attr("href"), function (html) {
                    $("#showCart").html(html);
                });
            });

            // ================= UPDATE CART =================
            $(document).on("click", "#btnUpdateCart", function () {
                var f = $("#formEditCart");

                if (f.length === 0) {
                    console.log("Không tìm thấy formEditCart");
                    return;
                }

                $.post(f.attr("action"), f.serialize(), function (res) {
                    console.log(res);

                    if (res.code == 1) {
                        loadCart();
                    } else {
                        alert(res.message);
                    }
                });
            });

            // ================= DELETE / CLEAR =================
                $(document).on("click", ".ajax-cart-action", function (e) {
        e.preventDefault();

        var url = $(this).attr("href");

        $.post(url, function () {
            loadCart();
        });
    });

            // ================= CLOSE EDIT =================
            $(document).on("click", ".btn-close-cart", function () {
                loadCart();
            });

            // ================= CREATE ORDER =================
            $("#formOrder").submit(function (e) {
                e.preventDefault();
                var f = $(this);

                $.post(f.attr("action"), f.serialize(), function (res) {
                    if (res.success) {
                        alert("Tạo đơn thành công!");
                        loadCart();
                    } else {
                        alert(res.message);
                    }
                });
            });
        });

        // ================= FUNCTIONS =================

        function searchProduct(page) {
            $.get('@Url.Action("SearchProduct", "Order")', {
                searchValue: $("input[name='searchValue']").val(),
                page: page,
                pageSize: 5
            }, function (html) {
                $("#searchProductResult").html(html);
            });
        }

        function loadCart() {
            $.get('@Url.Action("ShowCart", "Order")', function (html) {
                $("#showCart").html(html);
            });
        }
</script>
