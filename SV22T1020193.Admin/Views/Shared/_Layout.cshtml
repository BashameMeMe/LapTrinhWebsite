<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>LiteCommerce</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <link rel="stylesheet" href="~/lib/overlay-scrollbars/overlayscrollbars.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
</head>

<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open bg-body-tertiary">
    <div class="app-wrapper">
        <!--begin::Header-->
        <partial name="_Header" />
        <!--end::Header-->
        <!--begin::Sidebar-->
        <partial name="_Sidebar" />
        <!--end::Sidebar-->
        <!--begin::App Main-->
        <main class="app-main">
            <!--begin::App Content Header-->
            @RenderBody()
            <!--end::App Content-->
        </main>
        <!--end::App Main-->
        <!--begin::Footer-->
        <partial name="_Footer" />
        <!--end::Footer-->
    </div>

    <div class="modal fade" id="exampleModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Tiêu đề Modal</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Nội dung modal ở đây...
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Đóng
                    </button>
                    <button type="button" class="btn btn-primary">
                        Lưu
                    </button>
                </div>

            </div>
        </div>
    </div>

    <script src="lib/overlay-scrollbars/overlayscrollbars.browser.es6.min.js"></script>
    <script src="lib/popperjs/popper.min.js"></script>
    <script src="lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script type="module" src="lib/adminlte/js/adminlte.js"></script>

</body>

</html>