@model PagedResult<Customer>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.CustomerName</td>
                        <td>@item.ContactName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.Province</td>
                        <td class="text-center">
                            @if (item.IsLocked == true)
                            {
                                <span class="badge bg-warning">Bi khoa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }

                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a href="~/Customer/ChangePassword/@item.CustomerID" class="btn btn-sm btn-warning ms-2">
                                <i class="bi bi-key"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @* Nút về trang đầu *@
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), 1)">
                        <i class="bi bi-chevron-double-left"></i> Trang đầu
                    </a>
                </li>

                @for (int p = 1; p <= Model.PageCount; p++)
                {
                    // Hiển thị trang 1, trang cuối và các trang lân cận trang hiện tại (khoảng cách 3)
                    if (p == 1 || p == Model.PageCount || (p >= Model.Page - 3 && p <= Model.Page + 3))
                    {
                        if (p == Model.Page)
                        {
                            <li class="page-item active"><span class="page-link">@p</span></li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="javascript:;"
                                   onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">
                                    @p
                                </a>
                            </li>
                        }
                    }
                    // Hiển thị dấu chấm lửng để tránh tràn thanh phân trang
                    else if (p == Model.Page - 4 || p == Model.Page + 4)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                @* Nút tới trang cuối *@
                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @Model.PageCount)">
                        Trang cuối <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>
</div>
