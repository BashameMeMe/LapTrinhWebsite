@{
    ViewData["Title"] = "Xóa khách hàng";
    Layout = "_Layout";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="mb-0 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            Xác nhận xóa khách hàng
        </h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <div class="card border-danger">
            <div class="card-body">

                <p class="fs-5">
                    Bạn có chắc chắn muốn <strong class="text-danger">xóa</strong>
                    khách hàng này không?
                </p>

                <div class="alert alert-warning">
                    <i class="bi bi-info-circle"></i>
                    Thao tác này <strong>không thể hoàn tác</strong>.
                </div>

                <!-- Thông tin khách hàng (chỉ hiển thị) -->
                <dl class="row mb-4">
                    <dt class="col-sm-3">Tên khách hàng</dt>
                    <dd class="col-sm-9">Nguyễn Văn A</dd>

                    <dt class="col-sm-3">Người liên hệ</dt>
                    <dd class="col-sm-9">Nguyễn Văn A</dd>

                    <dt class="col-sm-3">Điện thoại</dt>
                    <dd class="col-sm-9">0909123456</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">a@gmail.com</dd>

                    <dt class="col-sm-3">Địa chỉ</dt>
                    <dd class="col-sm-9">123 Lê Lợi, TP.HCM</dd>
                </dl>

                <!-- Buttons -->
                <form method="post" class="text-end">
                    <a asp-action="Index"
                       class="btn btn-secondary me-2">
                        <i class="bi bi-x-circle"></i> Hủy
                    </a>

                    <button type="submit"
                            class="btn btn-danger">
                        <i class="bi bi-trash"></i> Xác nhận xóa
                    </button>
                </form>

            </div>
        </div>

    </div>
</div>
