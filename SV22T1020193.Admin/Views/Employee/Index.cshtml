@using SV22T1020193.Models.Common
@model PaginationSearchInput

@{
    ViewBag.Title = "Quản lý nhân viên";
}

@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Employee/Search"
              data-target="searchResult"
              onsubmit="return doSearch(this);">

            <input type="hidden" name="Page" value="@Model.Page" />
            <input type="hidden" name="PageSize" value="@Model.PageSize" />

            <div class="input-group">
                <input type="text"
                       name="SearchValue"
                       value="@Model.SearchValue"
                       class="form-control"
                       placeholder="Tên nhân viên..." autofocus />

                <button class="btn btn-info">
                    <i class="bi bi-search me-1"></i>
                    Tìm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    <!-- Kết quả sẽ load bằng AJAX -->
</div>

@section scripts {
    <script>
        function doSearch(form) {
            var url = form.action;
            var data = $(form).serialize();

            $.get(url, data, function (html) {
                $("#searchResult").html(html);
            });

            return false;
        }

        // load lần đầu
        $(document).ready(function () {
            $("#formSearch").submit();
        });
    </script>
}