@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<!-- Header -->
<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h3 class="mb-0">Nhân viên</h3>
            </div>
        </div>
    </div>
</div>

<!-- Content -->
<div class="app-content">
    <div class="container-fluid">

        <!-- Search + Create -->
        <div class="card mb-3">
            <div class="card-body">
                <form method="get"
                      asp-controller="Employee"
                      asp-action="Index"
                      class="row g-2 align-items-center">

                    <div class="col-md-4">
                        <input type="text"
                               name="searchValue"
                               class="form-control"
                               placeholder="Nhập tên nhân viên cần tìm..." />
                    </div>

                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>

                    <div class="col-auto">
                        <a asp-controller="Employee"
                           asp-action="Create"
                           class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Thêm mới
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Result count -->
        <div class="mb-2">
            <span class="text-muted">
                Tìm thấy <strong>2</strong> dòng dữ liệu
            </span>
        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Họ tên</th>
                            <th>Ngày sinh</th>
                            <th>Địa chỉ</th>
                            <th>Điện thoại</th>
                            <th>Email</th>
                            <th>Ảnh</th>
                            <th>Trạng thái</th>
                            <th>Vai trò</th>
                            <th style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>

                        <!-- Sample row -->
                        <tr>
                            <td>Nguyễn Văn A</td>
                            <td>15/03/1995</td>
                            <td>Hà Nội</td>
                            <td>0909 111 222</td>
                            <td>vana@gmail.com</td>
                            <td class="text-center">
                                <img src="~/images/employees/default.png"
                                     class="rounded-circle"
                                     width="40"
                                     height="40"
                                     alt="Photo" />
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success">Đang làm</span>
                            </td>
                            <td>
                                Admin, Sales
                            </td>
                            <td class="text-center">
                                <a href="#"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="#"
                                   class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td>Trần Thị B</td>
                            <td>22/08/1998</td>
                            <td>TP. Hồ Chí Minh</td>
                            <td>0912 333 444</td>
                            <td>thib@gmail.com</td>
                            <td class="text-center">
                                <img src="~/images/employees/default.png"
                                     class="rounded-circle"
                                     width="40"
                                     height="40"
                                     alt="Photo" />
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">Nghỉ việc</span>
                            </td>
                            <td>
                                Shipper
                            </td>
                            <td class="text-center">
                                <a href="#"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="#"
                                   class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer clearfix">
                <ul class="pagination pagination-sm m-0 float-end">
                    <li class="page-item disabled">
                        <a class="page-link">«</a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link">»</a>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
