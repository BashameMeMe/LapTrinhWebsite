@{
    ViewData["Title"] = "Phân quyền nhân viên";
    Layout = "_Layout";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3>Phân quyền nhân viên</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body">

                <form method="post">

                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="role1" />
                        <label class="form-check-label" for="role1">Admin</label>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="role2" />
                        <label class="form-check-label" for="role2">Sales</label>
                    </div>

                    <div class="form-check mb-4">
                        <input type="checkbox" class="form-check-input" id="role3" />
                        <label class="form-check-label" for="role3">Shipper</label>
                    </div>

                    <div class="text-end">
                        <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                        <button type="submit" class="btn btn-primary">Lưu quyền</button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>