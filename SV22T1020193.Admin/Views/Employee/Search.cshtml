@model SV22T1020193.Models.Common.PagedResult<SV22T1020193.Models.HR.Employee>

<div class="mb-2 text-muted">
    Có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center" style="width:140px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.DataItems.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            Không có dữ liệu
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>

                            <td class="text-center">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Nghỉ</span>
                                }
                            </td>

                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>

                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning">
                                    <i class="bi bi-key"></i>
                                </a>

                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    <div class="card-footer">
        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= Math.Ceiling((double)Model.RowCount / Model.PageSize); i++)
            {
                if (i == Model.Page)
                {
                    <li class="page-item active">
                        <a class="page-link" href="#">@i</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:;"
                           onclick="goToPage(@i)">
                            @i
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>

<script>
    function goToPage(page) {
        $("input[name='Page']").val(page);
        $("#formSearch").submit();
    }
</script>