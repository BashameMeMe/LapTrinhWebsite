@model SV22T1020193.Models.HR.Employee

@{
    ViewBag.Title = "Xóa nhân viên";
}

@section PageToolBar {
    @if ((bool?)ViewBag.AllowDelete == true)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            Xóa
        </button>
    }
    <a href="~/Employee" class="btn btn-secondary ms-1">Quay lại</a>
}

<div class="card">
    <div class="card-body">

        <form id="formDelete" method="post" action="~/Employee/Delete/@Model.EmployeeID">

            @if ((bool?)ViewBag.AllowDelete == true)
            {
                <div class="alert alert-warning">
                    Bạn có chắc muốn xóa?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    Không thể xóa (đang được sử dụng)
                </div>
            }

            <dl class="row">
                <dt class="col-sm-3">Họ tên</dt>
                <dd class="col-sm-9">@Model.FullName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>

        </form>

    </div>
</div>