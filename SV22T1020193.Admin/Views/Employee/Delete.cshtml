@{
    ViewData["Title"] = "Xóa nhân viên";
    Layout = "_Layout";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="text-danger">Xác nhận xóa nhân viên</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <div class="card border-danger">
            <div class="card-body">

                <div class="alert alert-warning">
                    Bạn có chắc chắn muốn xóa nhân viên này?
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Họ tên</dt>
                    <dd class="col-sm-9">Nguyễn Văn A</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">vana@gmail.com</dd>
                </dl>

                <form method="post" class="text-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
                </form>

            </div>
        </div>

    </div>
</div>