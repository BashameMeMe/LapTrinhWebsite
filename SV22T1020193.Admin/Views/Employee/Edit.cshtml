@{
    ViewData["Title"] = ViewBag.Title ?? "Cập nhật nhân viên";
    Layout = "_Layout";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3>@ViewData["Title"]</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body">

                <form method="post" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input type="text" name="FullName" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ngày sinh</label>
                        <input type="date" name="BirthDate" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" name="Address" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Điện thoại</label>
                        <input type="text" name="Phone" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ảnh</label>
                        <input type="file" name="Photo" class="form-control" />
                    </div>

                    <div class="form-check mb-4">
                        <input type="checkbox" name="IsWorking" class="form-check-input" id="IsWorking" />
                        <label class="form-check-label" for="IsWorking">Đang làm việc</label>
                    </div>

                    <div class="text-end">
                        <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                        <button type="reset" class="btn btn-warning me-2">Reset</button>
                        <button type="submit" class="btn btn-primary">Xác nhận</button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>