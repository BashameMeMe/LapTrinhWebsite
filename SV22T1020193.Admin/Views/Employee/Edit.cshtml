@model SV22T1020193.Models.HR.Employee

@{
    ViewBag.Title = ViewBag.Title ?? "Cập nhật nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">Quay lại</a>
}

<div class="card">
    <div class="card-body">

        <form id="formEdit" method="post" action="~/Employee/Save">

            <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />

            <div class="mb-3">
                <label>Họ tên</label>
                <input type="text" name="FullName" value="@Model.FullName" class="form-control" />
                @Html.ValidationMessage("FullName")
            </div>

            <div class="mb-3">
                <label>Ngày sinh</label>
                <input type="date" name="BirthDate"
                       value="@Model.BirthDate?.ToString("yyyy-MM-dd")"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label>Địa chỉ</label>
                <input type="text" name="Address" value="@Model.Address" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Điện thoại</label>
                <input type="text" name="Phone" value="@Model.Phone" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Email</label>
                <input type="email" name="Email" value="@Model.Email" class="form-control" />
                @Html.ValidationMessage("Email")
            </div>

            <div class="form-check">
                <input type="checkbox" name="IsWorking" value="true"
                       @(Model.IsWorking == true ? "checked" : "") />
                <label>Đang làm việc</label>
            </div>

        </form>

    </div>
</div>