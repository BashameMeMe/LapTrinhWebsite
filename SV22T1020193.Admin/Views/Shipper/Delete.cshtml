@{
    ViewData["Title"] = "Xóa Shipper";
}

<div class="app-content-header">
    <div class="container-fluid">
        <h3 class="text-danger">🗑 Xác nhận xóa Shipper</h3>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <div class="card border-danger shadow-sm">
            <div class="card-body">

                <div class="alert alert-warning">
                    Bạn có chắc chắn muốn xóa shipper này?
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Tên Shipper</dt>
                    <dd class="col-sm-9">Nguyễn Văn A</dd>

                    <dt class="col-sm-3">Số điện thoại</dt>
                    <dd class="col-sm-9">0901234567</dd>

                    <dt class="col-sm-3">Trạng thái</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-success">Hoạt động</span>
                    </dd>
                </dl>

                <form method="post" class="text-end">

                    <a asp-action="Index"
                       class="btn btn-secondary me-2">
                        Hủy
                    </a>

                    <button type="submit"
                            class="btn btn-danger">
                        Xác nhận xóa
                    </button>

                </form>

            </div>
        </div>

    </div>
</div>