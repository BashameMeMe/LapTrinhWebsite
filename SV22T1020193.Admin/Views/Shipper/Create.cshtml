@model SV22T1020193.Models.Partner.Shipper

@{
    bool isEdit = Model != null && Model.ShipperID > 0;
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu
    </button>

    <a href="~/Shipper" class="btn btn-secondary">
        Quay lại
    </a>
}

<div class="card">
    <div class="card-body">
        <form id="formEdit" method="post"
              asp-controller="Shipper"
              asp-action="@(isEdit ? "Edit" : "Create")">

            @if (isEdit)
            {
                <input type="hidden" asp-for="ShipperID" />
            }

            <div class="mb-3">
                <label>Tên người giao hàng</label>
                <input asp-for="ShipperName" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Điện thoại</label>
                <input asp-for="Phone" class="form-control" />
            </div>

        </form>
    </div>
</div>