@{
    ViewData["Title"] = "Quản lý Shipper";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="mb-0">🚚 Quản lý Shipper</h3>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle me-1"></i> Thêm shipper
            </a>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <!-- Search Card -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <form method="get"
                      asp-controller="Shipper"
                      asp-action="Index"
                      class="row g-2 align-items-center">

                    <div class="col-md-4">
                        <input type="text"
                               name="searchValue"
                               value="@Context.Request.Query["searchValue"]"
                               class="form-control"
                               placeholder="🔍 Tìm kiếm shipper..." />
                    </div>

                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <!-- Result -->
        <div class="mb-3">
            <span class="badge bg-info">
                Tổng cộng: 6 Shipper
            </span>
        </div>

        <!-- Table -->
        <div class="card shadow-sm border-0">
            <div class="card-body table-responsive p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width:60px;"></th>
                            <th>Tên Shipper</th>
                            <th>Số điện thoại</th>
                            <th>Trạng thái</th>
                            <th style="width:180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>

                        <!-- Row 1 -->
                        <tr>
                            <td class="text-center">
                                <img src="~/images/employees/default.png"
                                     class="rounded-circle"
                                     width="45" height="45" />
                            </td>
                            <td>Nguyễn Văn A</td>
                            <td>0901 234 567</td>
                            <td class="text-center">
                                <span class="badge bg-success">Hoạt động</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="1"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="1"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
