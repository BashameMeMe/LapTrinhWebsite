@model SV22T1020193.Models.Common.PaginationSearchInput

@{
    ViewBag.Title = "Quản lý Người giao hàng";
}

<h2>Quản lý Người giao hàng</h2>

<form id="formSearch" method="post" action="~/Shipper/Search">
    <div class="row mb-2">

        <div class="col-md-4">
            <input type="text"
                   name="SearchValue"
                   class="form-control"
                   placeholder="Tên người giao hàng..."
                   value="@Model.SearchValue" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-info">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
        </div>

        <div class="col-md-3 text-end">
            <a href="~/Shipper/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Bổ sung
            </a>
        </div>

    </div>

    <!-- phân trang -->
    <input type="hidden" name="Page" value="@Model.Page" />
    <input type="hidden" name="PageSize" value="@Model.PageSize" />
</form>

<!-- nơi hiển thị dữ liệu từ DB -->
<div id="searchResult"></div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

        // load dữ liệu lần đầu từ DB
        loadData();

        // submit form -> gọi AJAX
        $("#formSearch").submit(function (e) {
            e.preventDefault();
            loadData();
        });
    });

    function loadData() {
        $.ajax({
            url: '/Shipper/Search',
            type: 'POST',
            data: $("#formSearch").serialize(),
            success: function (data) {
                $("#searchResult").html(data);
            },
            error: function () {
                alert("Lỗi tải dữ liệu");
            }
        });
    }

    function paginationSearch(page) {
        $("input[name='Page']").val(page);
        loadData();
    }
</script>